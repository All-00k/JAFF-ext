{
  "manifest_version": 3,
  "name": "JAFF",
  "version": "1.0",
  "description": "Automatically detects and fills forms",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}